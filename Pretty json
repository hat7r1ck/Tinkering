import json
import pandas as pd
from IPython.display import display, Markdown
import ipywidgets as widgets

# Dropdown to select output format
output_format = widgets.Dropdown(
    options=["Standard", "Markdown"],
    value="Standard",
    description="Output Format:",
    style={'description_width': 'initial'}
)

# Text area to paste JSON data
json_input = widgets.Textarea(
    description="Paste JSON:",
    layout=widgets.Layout(width="100%", height="200px"),
    placeholder="Paste your JSON log data here...",
)

# Button to process JSON data
process_button = widgets.Button(description="Process JSON")

# Output area for displaying results
output = widgets.Output()

# Function to process JSON when button is clicked
def process_json(b):
    with output:
        output.clear_output()  # Clear previous outputs
        raw_json = json_input.value  # Get JSON from text area
        
        try:
            # Parse the JSON
            parsed_json = json.loads(raw_json)
            
            if output_format.value == "Standard":
                display(Markdown("### Parsed JSON Log Data"))
                print(json.dumps(parsed_json, indent=4))

                # Convert to DataFrame and display if it's a list or dict of lists
                if isinstance(parsed_json, list):
                    df = pd.json_normalize(parsed_json)
                    display(Markdown("### Data in Tabular Format"))
                    display(df)
                elif isinstance(parsed_json, dict):
                    df = pd.json_normalize(parsed_json, sep="_")
                    display(Markdown("### Data in Tabular Format"))
                    display(df)

            elif output_format.value == "Markdown":
                if isinstance(parsed_json, list):
                    # Parse JSON list for Markdown table
                    df = pd.json_normalize(parsed_json)
                    markdown_table = df.to_markdown(index=False)
                    display(Markdown("### Markdown Table Output"))
                    display(Markdown(markdown_table))
                elif isinstance(parsed_json, dict):
                    # Parse JSON dict for Markdown table
                    df = pd.json_normalize(parsed_json, sep="_")
                    markdown_table = df.to_markdown(index=False)
                    display(Markdown("### Markdown Table Output"))
                    display(Markdown(markdown_table))
                else:
                    display(Markdown("JSON data format is not compatible with table conversion."))

        except json.JSONDecodeError:
            print("The input is not valid JSON. Please check the data and try again.")

# Link button to process function
process_button.on_click(process_json)

# Display widgets and output
display(output_format, json_input, process_button, output)
